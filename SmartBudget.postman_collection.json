							],
							"variable": [
								{
									"key": "accountId",
									"value": "",
									"description": "UUID de la cuenta"
								}
							]
						},
						"description": "Obtener los detalles de una cuenta específica"
					},
					"response": []
				},
				{
					"name": "Create Account",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    if (response.account && response.account.id) {",
									"        pm.environment.set(\"lastAccountId\", response.account.id);",
									"        console.log(\"Account ID guardado: \" + response.account.id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"balance\": 5000,\n  \"type\": \"ahorros\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/accounts",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"accounts"
							]
						},
						"description": "Crear una nueva cuenta para el usuario autenticado"
					},
					"response": []
				},
				{
					"name": "Create Account with Linked Account",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"balance\": 3000,\n  \"type\": \"corriente\",\n  \"account_linked\": \"{{lastAccountId}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/accounts",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"accounts"
							]
						},
						"description": "Crear una cuenta vinculada a otra cuenta existente"
					},
					"response": []
				},
				{
					"name": "Update Account",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"balance\": 7500,\n  \"type\": \"corriente\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/accounts/:accountId",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"accounts",
								":accountId"
							],
							"variable": [
								{
									"key": "accountId",
									"value": "{{lastAccountId}}",
									"description": "UUID de la cuenta a actualizar"
								}
							]
						},
						"description": "Actualizar una cuenta existente"
					},
					"response": []
				},
				{
